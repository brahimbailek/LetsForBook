// packages/database/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// ENUMS
// =============================================

enum UserRole {
  CLIENT
  PROFESSIONAL
  SALON_OWNER
  ADMIN
}

enum AppointmentStatus {
  PENDING           // Waiting for professional confirmation
  CONFIRMED         // Confirmed by professional
  CANCELLED_CLIENT  // Cancelled by client
  CANCELLED_SALON   // Cancelled by salon/professional
  COMPLETED         // Service completed
  NO_SHOW          // Client didn't show up
  IN_PROGRESS      // Service currently happening
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  REFUNDED
  FAILED
  CANCELLED
}

enum PaymentType {
  DEPOSIT
  FULL_PAYMENT
}

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  NEW_BOOKING_REQUEST
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  REVIEW_REQUEST
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AvailabilityExceptionType {
  UNAVAILABLE  // Day off, holiday, etc.
  CUSTOM       // Custom hours for specific date
}

// =============================================
// USER & AUTHENTICATION
// =============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  phone         String?   @unique
  phoneVerified DateTime?

  firstName     String
  lastName      String
  avatar        String?

  role          UserRole  @default(CLIENT)

  // Hashed password (for email/password auth)
  password      String?

  // Auth related
  accounts      Account[]
  sessions      Session[]

  // User relationships
  clientProfile       ClientProfile?
  professionalProfile ProfessionalProfile?
  salonOwner          Salon[]              @relation("SalonOwner")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  @@index([email])
  @@index([phone])
  @@map("authen_all_users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("authen_oauth")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("authen_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("authen_tokens")
}

// =============================================
// CLIENT PROFILE
// =============================================

model ClientProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Preferences
  preferredLanguage String @default("en")
  marketingOptIn    Boolean @default(false)

  // Relationships
  appointments Appointment[]
  reviews      Review[]
  favorites    FavoriteSalon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account_clients")
}

// =============================================
// SALON & LOCATION
// =============================================

model Salon {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text

  // Contact info
  email       String
  phone       String
  website     String?

  // Location
  address     String
  city        String
  postalCode  String
  country     String  @default("FR")
  latitude    Float?
  longitude   Float?

  // Media
  logo        String?
  coverImage  String?
  images      String[] // Array of image URLs

  // Business info
  registrationNumber String?
  vatNumber          String?

  // Owner
  ownerId     String
  owner       User     @relation("SalonOwner", fields: [ownerId], references: [id])

  // Settings
  timezone            String   @default("Europe/Paris")
  currency            String   @default("EUR")
  bookingBufferMinutes Int     @default(0) // Buffer between appointments
  cancellationPolicyHours Int  @default(24)
  depositRequired     Boolean  @default(false)
  depositPercentage   Int?     // 0-100

  // Status
  verified    Boolean  @default(false)
  active      Boolean  @default(true)
  published   Boolean  @default(false) // Visible publiquement uniquement après abonnement

  // Relationships
  professionals ProfessionalProfile[]
  services      Service[]
  categories    Category[]
  appointments  Appointment[]
  reviews       Review[]
  availability  SalonAvailability[]
  favorites     FavoriteSalon[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete

  @@index([slug])
  @@index([city])
  @@index([ownerId])
  @@index([active, verified])
  @@map("account_entreprises")
}

model FavoriteSalon {
  id        String        @id @default(cuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salonId   String
  salon     Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([clientId, salonId])
  @@map("salon_favorites")
}

// =============================================
// PROFESSIONAL PROFILE
// =============================================

model ProfessionalProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  salonId     String
  salon       Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)

  title       String? // e.g., "Master Hair Stylist"
  bio         String? @db.Text

  // Professional info
  specialties String[] // Array of specialties
  experience  Int?     // Years of experience

  // Settings
  acceptsOnlineBookings Boolean @default(true)
  active                Boolean @default(true)

  // Relationships
  services      ProfessionalService[]
  appointments  Appointment[]
  availability  ProfessionalAvailability[]
  exceptions    AvailabilityException[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([salonId])
  @@index([active])
  @@map("account_pro")
}

// =============================================
// CATEGORIES
// =============================================

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String
  description String? @db.Text
  icon        String? // Emoji or icon name
  color       String? // Hex color for UI

  order       Int     @default(0) // For sorting
  active      Boolean @default(true)

  // Salon ownership (null = global category for homepage browsing)
  salonId     String?
  salon       Salon?  @relation(fields: [salonId], references: [id], onDelete: Cascade)

  // Parent-child hierarchy (sub-categories)
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("CategoryHierarchy")

  // Relationships
  services    Service[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([salonId, slug])
  @@index([active])
  @@index([order])
  @@index([salonId])
  @@index([parentId])
  @@map("salon_categories")
}

// =============================================
// SERVICES
// =============================================

model Service {
  id          String  @id @default(cuid())
  salonId     String
  salon       Salon   @relation(fields: [salonId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text

  // Category relationship
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])

  // Pricing
  price       Int     // In cents
  currency    String  @default("EUR")

  // Duration
  durationMinutes Int // Service duration in minutes

  // Media
  image       String?

  // Status
  active      Boolean @default(true)

  // Ordering within category
  order       Int     @default(0)

  // Relationships
  professionals ProfessionalService[]
  appointments  AppointmentService[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete

  @@index([salonId])
  @@index([categoryId])
  @@index([active])
  @@index([order])
  @@map("salon_services")
}

// Join table: which professionals offer which services
model ProfessionalService {
  id             String              @id @default(cuid())
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  serviceId      String
  service        Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Optional: custom price or duration for this professional
  customPrice          Int?
  customDurationMinutes Int?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([professionalId, serviceId])
  @@index([professionalId])
  @@index([serviceId])
  @@map("pro_services")
}

// =============================================
// APPOINTMENTS / BOOKINGS
// =============================================

model Appointment {
  id            String            @id @default(cuid())

  // Client
  clientId      String
  client        ClientProfile     @relation(fields: [clientId], references: [id])

  // Salon & Professional
  salonId       String
  salon         Salon             @relation(fields: [salonId], references: [id])
  professionalId String
  professional  ProfessionalProfile @relation(fields: [professionalId], references: [id])

  // Timing
  startTime     DateTime
  endTime       DateTime
  timezone      String            @default("Europe/Paris")

  // Status
  status        AppointmentStatus @default(PENDING)

  // Notes
  clientNotes   String?           @db.Text
  internalNotes String?           @db.Text // Professional's private notes

  // Cancellation
  cancelledAt   DateTime?
  cancelReason  String?           @db.Text

  // Relationships
  services      AppointmentService[]
  payment       Payment?
  notifications Notification[]
  review        Review?

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([clientId])
  @@index([salonId])
  @@index([professionalId])
  @@index([startTime])
  @@index([status])
  @@index([startTime, professionalId]) // For availability queries
  @@map("booking_appointments")
}

// Join table: services in an appointment
model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service     @relation(fields: [serviceId], references: [id])

  // Snapshot of service details at booking time
  serviceName   String
  price         Int        // In cents
  duration      Int        // In minutes

  createdAt DateTime @default(now())

  @@index([appointmentId])
  @@map("booking_appointment_services")
}

// =============================================
// AVAILABILITY
// =============================================

// Salon-wide availability (default hours)
model SalonAvailability {
  id        String    @id @default(cuid())
  salonId   String
  salon     Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  openTime  String    // HH:mm format (e.g., "09:00")
  closeTime String    // HH:mm format (e.g., "18:00")

  isClosed  Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([salonId, dayOfWeek])
  @@index([salonId])
  @@map("salon_availability")
}

// Professional-specific availability (overrides salon availability)
model ProfessionalAvailability {
  id             String              @id @default(cuid())
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  startTime String    // HH:mm format
  endTime   String    // HH:mm format

  // Optional: breaks
  breakStartTime String? // HH:mm format
  breakEndTime   String? // HH:mm format

  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([professionalId, dayOfWeek])
  @@index([professionalId])
  @@map("pro_availability")
}

// Availability exceptions (holidays, sick days, special hours)
model AvailabilityException {
  id             String                     @id @default(cuid())
  professionalId String
  professional   ProfessionalProfile        @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  date           DateTime                   @db.Date
  type           AvailabilityExceptionType

  // For CUSTOM type
  startTime      String?                    // HH:mm format
  endTime        String?                    // HH:mm format

  reason         String?                    @db.Text

  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([professionalId])
  @@index([date])
  @@map("pro_exceptions")
}

// =============================================
// PAYMENTS
// =============================================

model Payment {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  // Amount
  amount        Int           // In cents
  currency      String        @default("EUR")
  type          PaymentType

  // Status
  status        PaymentStatus @default(PENDING)

  // Stripe
  stripePaymentIntentId String? @unique
  stripeChargeId        String?
  stripeRefundId        String?

  // Timestamps
  paidAt        DateTime?
  refundedAt    DateTime?
  failedAt      DateTime?

  // Metadata
  metadata      Json?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([appointmentId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@map("booking_payments")
}

// =============================================
// NOTIFICATIONS
// =============================================

model Notification {
  id            String              @id @default(cuid())
  userId        String

  type          NotificationType
  channel       NotificationChannel

  // Recipients
  recipient     String              // Email address or phone number

  // Content
  subject       String?
  body          String              @db.Text

  // Appointment reference (if applicable)
  appointmentId String?
  appointment   Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  // Status
  sent          Boolean             @default(false)
  sentAt        DateTime?
  failed        Boolean             @default(false)
  failureReason String?             @db.Text

  // For retries
  attempts      Int                 @default(0)

  // Metadata
  metadata      Json?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([userId])
  @@index([appointmentId])
  @@index([sent])
  @@index([channel])
  @@map("booking_notifications")
}

// =============================================
// REVIEWS
// =============================================

model Review {
  id            String        @id @default(cuid())
  appointmentId String        @unique
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  clientId      String
  client        ClientProfile @relation(fields: [clientId], references: [id])

  salonId       String
  salon         Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)

  // Rating (1-5 stars)
  rating        Int

  // Review content
  comment       String?       @db.Text

  // Response from salon
  response      String?       @db.Text
  respondedAt   DateTime?

  // Status
  published     Boolean       @default(true)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([clientId])
  @@index([salonId])
  @@index([rating])
  @@index([published])
  @@map("booking_reviews")
}

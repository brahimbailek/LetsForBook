# Database
DATABASE_URL="postgresql://user:password@localhost:5432/letsforbook?schema=public"
DATABASE_DIRECT_URL="postgresql://user:password@localhost:5432/letsforbook?schema=public" # Optional: for migrations

# NextAuth.js
NEXTAUTH_SECRET="your-super-secret-min-32-characters-long-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Twilio (SMS)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+33123456789"

# Resend (Email)
RESEND_API_KEY="re_..."

# Redis (Upstash)
UPSTASH_REDIS_URL="https://..."
